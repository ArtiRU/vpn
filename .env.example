# ======================
# Server Configuration
# ======================
PORT=3000
NODE_ENV=development

# ======================
# CORS Configuration
# ======================
CORS_ORIGIN=*

# ======================
# Database Configuration
# ======================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=root
DB_DATABASE=vpn
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ======================
# JWT Configuration
# ======================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ======================
# YooKassa Payment Configuration
# ======================
# Получите эти данные в личном кабинете ЮКассы: https://yookassa.ru/my
# Инструкция по настройке в README.md
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here

# Цены подписок (в рублях)
YOOKASSA_MONTHLY_PRICE=500
YOOKASSA_YEARLY_PRICE=5000

# Валюта (ISO 4217: RUB, USD, EUR и т.д.)
YOOKASSA_CURRENCY=RUB

# ======================
# Frontend Configuration
# ======================
FRONTEND_URL=http://localhost:3000

# ======================
# Xray Panel Configuration (3X-UI)
# ======================
XRAY_PANEL_URL=http://localhost:2053
XRAY_PANEL_USERNAME=admin
XRAY_PANEL_PASSWORD=admin
