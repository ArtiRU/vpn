# ========================================
# VPN Backend - Environment Variables
# ========================================
# ВАЖНО: Скопируйте этот файл в .env и заполните реальными значениями
# Команда: cp .env.example .env
# НИКОГДА не коммитьте файл .env в git!
# ========================================

# ========================================
# Server Configuration
# ========================================
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# ========================================
# Database Configuration (PostgreSQL)
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
DB_DATABASE=vpn

# ВАЖНО: В продакшене установите DB_SYNCHRONIZE=false и используйте миграции!
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ========================================
# JWT Authentication
# ========================================
# Генерация секретного ключа: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=15m

# Refresh Token
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# Stripe Payment Integration
# ========================================
# Получите ключи на: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Product Price IDs (создайте на https://dashboard.stripe.com/products)
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id
STRIPE_YEARLY_PRICE_ID=price_your_yearly_price_id

# ========================================
# Frontend URL
# ========================================
# URL вашего frontend приложения (для редиректов после оплаты)
FRONTEND_URL=http://localhost:3000

# ========================================
# Optional: pgAdmin (только для разработки)
# ========================================
# PGADMIN_EMAIL=admin@vpn.local
# PGADMIN_PASSWORD=admin

# ========================================
# WireGuard Management (будет добавлено позже)
# ========================================
# WIREGUARD_API_URL=http://your-wireguard-management-api:8080
# WIREGUARD_API_KEY=your-api-key
